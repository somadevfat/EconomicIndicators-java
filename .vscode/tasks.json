{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Maven Clean Verify",
      "type": "shell",
      "command": "mvn clean verify -B",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": ["$maven"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
} 